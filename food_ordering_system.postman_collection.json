        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.accessToken) {",
                  "    pm.collectionVariables.set(\"adminToken\", jsonData.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
